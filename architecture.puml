@startuml architecture
!theme plain
top to bottom direction
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam shadowing false
skinparam roundcorner 14
skinparam nodesep 50
skinparam ranksep 60
skinparam ArrowThickness 2
skinparam ArrowFontSize 10

skinparam actor {
  BackgroundColor #dbeafe
  BorderColor #3b82f6
  FontColor #1e3a5f
  FontStyle bold
}
skinparam rectangle {
  BackgroundColor #f0f4ff
  BorderColor #93c5fd
  BorderThickness 2
  FontColor #1e3a5f
  FontStyle bold
  FontSize 11
}
skinparam package {
  BackgroundColor #f8fafc
  BorderColor #64748b
  FontColor #1e3a5f
  FontStyle bold
  FontSize 13
}
skinparam database {
  BackgroundColor #faf5ff
  BorderColor #a855f7
  FontColor #6b21a8
  FontSize 11
}

' ── HOST ──────────────────────────────────────────────────────────
actor "👤 דפדפן סטודנט" as browser
actor "📊 לוח מרצה" as prof

' ── DOCKER COMPOSE ────────────────────────────────────────────────
package "🐳 Docker Compose — exam-net  10.99.0.0/24" #f0f9ff {

  package "תשתית" #e0f2fe {
    rectangle "🏠 DHCP\n10.99.0.3  UDP:67\npool 10.99.0.100–149" as dhcp #f0fdf4
    rectangle "🌐 DNS Resolver\n10.99.0.2  UDP:53\nאיטרטיבי / רקורסיבי\nRoot→TLD→Auth" as dns #dbeafe
  }

  package "📦 קונטיינרי לקוח  ×N  (ניתן להרחבה)" #fffbeb {
    rectangle "🐳 client-1/2/N\nIP: 10.99.0.100+\nnginx :80  |  supervisord\nגשרי WS: RUDP · TCP-sync · TCP-nosync" as client #fef9c3
  }

  package "⚡ שרתי מבחן RUDP  ×3  UDP:9000" #f0fdf4 {
    rectangle "rudp-server  ×3\n10.99.0.20/21/22\nExamSendCoordinator\nZS wire  |  sliding window ARQ" as rudp #e0fdf4
  }

  package "🔌 שרתי מבחן TCP  TCP:9001" #fdf4ff {
    rectangle "tcp-sync  10.99.0.23\nSYNC=1  ExamSendCoordinator\nשליחה מדורגת לפי D_i" as tcps #f3e8ff
    rectangle "tcp-nosync  10.99.0.24\nSYNC=0  שליחה מיידית\nבסיס השוואה" as tcpn #fff7ed
  }

  package "💾 Docker Named Volumes" #f1f5f9 {
    database "exam-shared\nstart_at · exam.json · clients.json" as shared_vol
    database "answers-data\nanswers/{exam_id}/{client}.json" as answers_vol
  }

  rectangle "📋 Admin  FastAPI\n10.99.0.30  :9999" as admin #fef2ff
}

' ── ARROWS ────────────────────────────────────────────────────────
browser  -[#2563eb]->        client      : "① HTTP :80  טעינת SPA\n   WS /ws · /ws-tcp-sync · /ws-tcp-nosync"
dhcp     -[#4ade80]->        client      : "② DHCPACK\n   הקצאת IP"
client   -[#60a5fa]->        dns         : "③ DNS Q  server.exam.lan\n   → A×3 round-robin"

client   -[#16a34a]->  rudp        : "④a RUDP UDP"
client   -[#7c3aed]->  tcps        : "④b TCP סנכרון"
client   -[#ea580c]->  tcpn        : "④c TCP baseline"

rudp     -[#16a34a]->  shared_vol  : "⑤ כתיבה"
rudp     -[#16a34a]->  answers_vol
tcps     -[#7c3aed]->  shared_vol
tcps     -[#7c3aed]->  answers_vol
tcpn     -[#ea580c]->  answers_vol

admin    -[#a855f7]->  shared_vol  : "⑥ קריאה"
admin    -[#a855f7]->  answers_vol
browser  -[#94a3b8]->  admin       : "⑦ HTTP :9999"
prof     -[#0ea5e9]->  client      : "netem / DNS"

legend bottom right
  | <color:#16a34a><b>——</b></color> | RUDP + סנכרון |
  | <color:#7c3aed><b>——</b></color> | TCP + סנכרון  |
  | <color:#ea580c><b>——</b></color> | TCP ללא סנכרון |
  | <color:#60a5fa><b>——</b></color> | DNS |
  | <color:#2563eb><b>——</b></color> | HTTP / WS |
  | <color:#94a3b8><b>- -</b></color> | משני |
endlegend

@enduml
