@startuml diagram_client_flow
!theme plain
skinparam backgroundColor #FFFFFF
skinparam defaultFontName "Segoe UI"
skinparam defaultFontSize 12
skinparam defaultFontColor #1a1a2e
skinparam shadowing false
skinparam roundcorner 12

skinparam sequenceArrowThickness 1.8
skinparam sequenceArrowColor #2563eb
skinparam sequenceArrowFontColor #374151
skinparam sequenceArrowFontSize 11
skinparam sequenceArrowFontStyle bold
skinparam sequenceLifeLineBorderColor #93c5fd
skinparam sequenceLifeLineBackgroundColor #f0f4ff

skinparam participantBackgroundColor #f0f4ff
skinparam participantBorderColor #93c5fd
skinparam participantBorderThickness 2
skinparam participantFontColor #1e3a5f
skinparam participantFontSize 12
skinparam participantFontStyle bold
skinparam participantPadding 8

skinparam actorBackgroundColor #dbeafe
skinparam actorBorderColor #3b82f6
skinparam actorFontColor #1e3a8a
skinparam actorFontStyle bold

skinparam noteBackgroundColor #fefce8
skinparam noteBorderColor #f59e0b
skinparam noteBorderThickness 1.5
skinparam noteFontColor #374151
skinparam noteFontSize 11

skinparam dividerBackgroundColor #e0f2fe
skinparam dividerBorderColor #0ea5e9
skinparam dividerFontColor #0369a1
skinparam dividerFontStyle bold
skinparam dividerFontSize 13

skinparam boxBackgroundColor #f8fafc
skinparam boxBorderColor #94a3b8
skinparam boxFontColor #475569
skinparam boxFontStyle bold

autonumber "<font color=#6b7280><b>( 00 )</b></font>"

title <size:20><color:#1d4ed8>**זרימת לקוח חדש ברשת**</color></size>\n<size:12><color:#64748b>DHCP  →  DNS Iterative  →  RUDP Handshake  →  WebSocket  →  App</color></size>

' ── Participants ──────────────────────────────────────────
actor        "👤 סטודנט\n(דפדפן)"         as student  #dbeafe
participant  "🔧 entrypoint.sh\nclient-N"  as entry   #fefce8
participant  "🏠 dhcp-server\n10.99.0.3"   as dhcp    #f0fdf4
participant  "🔍 dns-resolver\n10.99.0.2"  as resolver #eff6ff

box "🌐 היררכיית DNS  (RFC 1034/1035)" #f0f9ff
  participant "dns-root\n10.99.0.10"  as droot #eff6ff
  participant "dns-tld\n10.99.0.11"   as dtld  #eff6ff
  participant "dns-auth\n10.99.0.12"  as dauth #f0fff4
end box

participant "⚡ nginx\n:80"           as nginx  #fffbeb
participant "🔗 ws_bridge\n:8081"     as bridge #fffbeb
participant "🖥 exam-server\n10.99.0.2x :9000" as exam #f0fdf4

' ══════════════════════════════════════════════════════════
== 📡  שלב 1 — אתחול ו-DHCP ==
' ══════════════════════════════════════════════════════════

entry  ->  dhcp   : **DHCPDISCOVER**\nbroadcast 255.255.255.255 UDP:67\nMAC + client-id
activate dhcp
dhcp   --> entry  : **DHCPOFFER**\nIP=10.99.0.1xx  mask=/24\ngw=10.99.0.1  DNS=10.99.0.2  lease=86400s
deactivate dhcp

entry  ->  dhcp   : **DHCPREQUEST**\nconfirming 10.99.0.1xx
activate dhcp
dhcp   --> entry  : **DHCPACK** ✓ חכירה אושרה
deactivate dhcp

note right of entry
  **ip addr add** 10.99.0.1xx/24 dev eth0
  **ip route add** default via 10.99.0.1
  **/etc/resolv.conf** ← nameserver 10.99.0.2
end note

entry -> entry : supervisord מפעיל\nnginx :80  +  ws_bridge :8081

' ══════════════════════════════════════════════════════════
== 🌐  שלב 2 — רזולוציית DNS (איטרטיבי, 3 hop) ==
' ══════════════════════════════════════════════════════════

bridge -> resolver : **Q** server.exam.lan **A?**  RD=1  UDP:53
note left of bridge
  Python getaddrinfo()
  משתמש ב-/etc/resolv.conf
  → 10.99.0.2:53
end note

activate resolver

resolver -> droot  : **Q** server.exam.lan A?  RD=0
activate droot
droot  --> resolver : **REFERRAL**  AA=0\nlan. NS ns1.lan.\nglue: ns1.lan. A 10.99.0.11
deactivate droot

resolver -> dtld   : **Q** server.exam.lan A?  RD=0
activate dtld
dtld   --> resolver : **REFERRAL**  AA=0\nexam.lan. NS ns1.exam.lan.\nglue: ns1.exam.lan. A 10.99.0.12
deactivate dtld

resolver -> dauth  : **Q** server.exam.lan A?  RD=0
activate dauth
dauth  --> resolver : **ANSWER**  AA=1\nserver.exam.lan A 10.99.0.20\nserver.exam.lan A 10.99.0.21\nserver.exam.lan A 10.99.0.22
deactivate dauth

resolver --> bridge : ✅ 3 רשומות A  (מטמון TTL=300s)
deactivate resolver

note right of resolver
  round-robin — ws_bridge בוחר
  כתובת אחת ושומר אותה
  (כל sessions → אותו שרת)
end note

' ══════════════════════════════════════════════════════════
== 🤝  שלב 3 — RUDP 3-Way Handshake ==
' ══════════════════════════════════════════════════════════

bridge -> exam : UDP **[SYN]**\nseq=0  win=8  flags=0x01
activate exam

exam   --> bridge : UDP **[SYN+ACK]**\nseq=0  ack=1  win=8  flags=0x03

bridge -> exam : UDP **[ACK]**\nseq=1  ack=1  flags=0x02

note right of bridge
  **handshake_rtt_ms** = RTT של הhandshake
  **rtt_ms** = EWMA עדכני
  שניהם נשמרים ב-RudpSocket
  ומוזרקים ל-hello בהמשך
end note

' ══════════════════════════════════════════════════════════
== 🌐  שלב 4 — WebSocket Upgrade (Browser → nginx → bridge) ==
' ══════════════════════════════════════════════════════════

student -> nginx  : GET **/ws** HTTP/1.1\nUpgrade: websocket\nConnection: Upgrade
activate nginx
nginx   -> bridge : **proxy_pass** :8081\n(HTTP Upgrade forwarded)
activate bridge

bridge --> student : **{"type":"connection_info"}**\nresolved_ip: 10.99.0.2x\nall_ips: [.20, .21, .22]\nhandshake_rtt_ms: 12.3\nrtt_ms: 11.8
deactivate nginx

' ══════════════════════════════════════════════════════════
== 💬  שלב 5 — הודעות פרוטוקול ראשוניות ==
' ══════════════════════════════════════════════════════════

student -> bridge : **{"type":"hello"}**\nclient_id: "abc"\nrtt_ms: 11.8

note right of bridge
  bridge **מזריק** rtt_ms
  ו-handshake_rtt_ms
  מה-RudpSocket לתוך hello
  לפני שליחה לשרת
end note

bridge -> exam : RUDP DATA **[hello]**\nclient_id:"abc"  rtt_ms:11.8\nhandshake_rtt_ms:12.3
exam  --> bridge : (שתיקה — רישום client בלבד)
deactivate exam
deactivate bridge

note over student, exam
  הלקוח מוכן — RTT sync יתחיל בשלב הבא
  ← ראה diagram_app_flow.puml לזרימת הבחינה המלאה →
end note

@enduml
